PORT='8000'
NODE_ENV='production'
SPORTMONKS_API_KEY='your_key'
SPORTMONKS_BASE='https://api.sportmonks.com/v3/football'
DBURI="mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority"
DBPW="db_password"
SELF_BASE='https://your-railway-domain.up.railway.app'
ADMIN_API_KEY='API_key_here'
OPENAI_API_KEY='OpenAI_key_here'
OPENAI_MODEL='gpt-4o-mini'

# Cron Job Control (set to 'true' only in production environment)
ENABLE_CRON='false'

# CORS - Additional allowed origins (comma-separated)
# Example: https://staging-preview.pages.dev,https://preview-abc123.pages.dev
CORS_ALLOWED_ORIGINS=''