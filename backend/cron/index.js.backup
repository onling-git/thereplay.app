// cron/index.js (CommonJS, no top-level await)
"use strict";

const cron = require("node-cron");
const axios = require("axios");

const BASE = process.env.SELF_BASE || "http://localhost:8000";
const ADMIN_KEY = process.env.ADMIN_API_KEY;

// Shared axios instance for internal API calls (centralises headers/timeouts)
const api = axios.create({ baseURL: BASE, headers: { 'x-api-key': ADMIN_KEY }, timeout: 30_000 });

// Simple in-memory caching for league discovery to avoid repeated /api/leagues calls
const LEAGUES_TTL_MS = Number(process.env.CRON_LEAGUES_TTL_MS || 5 * 60 * 1000); // 5 minutes by default
let _cachedLeagues = { ts: 0, data: null };

async function getLeaguesWithFallback(force = false) {
  if (!force && _cachedLeagues.data && (Date.now() - _cachedLeagues.ts) < LEAGUES_TTL_MS) {
    return _cachedLeagues.data;
  }

  let leagueIds = [];
  try {
    const r = await api.get('/api/leagues');
    if (Array.isArray(r.data)) leagueIds = r.data.map(l => ({ id: Number(l.id), name: l.name, region: l.region, country: l.country || null })).filter(x => Number.isFinite(x.id));
  } catch (e) {
    console.warn('[cron] Failed to fetch /api/leagues; attempting catalog fallback', e?.response?.data || e.message);
    try {
      await api.post('/api/sync/catalog/all', { mode: 'leagues' }, { timeout: 60_000 });
      const r2 = await api.get('/api/leagues');
      if (Array.isArray(r2.data)) leagueIds = r2.data.map(l => ({ id: Number(l.id), name: l.name, region: l.region, country: l.country || null })).filter(x => Number.isFinite(x.id));
    } catch (e2) {
      console.warn('[cron] Catalog fallback failed to provide leagues:', e2?.response?.data || e2.message);
    }
  }

  _cachedLeagues = { ts: Date.now(), data: leagueIds };
  return leagueIds;
}

// Simple sliding-window rate limiter for internal cron->server posts to avoid bursting
const CRON_PROVIDER_MAX_CALLS_PER_MIN = Number(process.env.CRON_PROVIDER_MAX_CALLS_PER_MIN || 60);
let _cronPostTimestamps = [];
async function throttledApiPost(path, body, opts = {}) {
  // remove timestamps older than 60s
  const now = Date.now();
  _cronPostTimestamps = _cronPostTimestamps.filter(ts => (now - ts) < 60_000);
  if (_cronPostTimestamps.length >= CRON_PROVIDER_MAX_CALLS_PER_MIN) {
    const oldest = _cronPostTimestamps[0];
    const waitMs = Math.max(50, 60_000 - (now - oldest));
    console.log(`[cron] Rate limiter active: waiting ${waitMs}ms before posting ${path}`);
    await sleep(waitMs);
  }
  // record timestamp and perform request
  _cronPostTimestamps.push(Date.now());
  return api.post(path, body, opts);
}

// Simple concurrency runner: run worker over items with maximum concurrency
async function runWithConcurrency(items, worker, concurrency = 1) {
  const results = [];
  let i = 0;
  const active = [];

  function enqueue() {
    if (i >= items.length) return null;
    const item = items[i++];
    const p = (async () => {
      try {
        return await worker(item);
      } catch (e) {
        throw e;
      }
    })();
    active.push(p);
    // when done remove from active
    p.then(() => { const idx = active.indexOf(p); if (idx !== -1) active.splice(idx, 1); }).catch(() => { const idx = active.indexOf(p); if (idx !== -1) active.splice(idx, 1); });
    return p;
  }

  // kick off initial batch
  for (let j = 0; j < concurrency; j++) enqueue();

  while (active.length) {
    await Promise.race(active);
    // fill up to concurrency
    while (active.length < concurrency && i < items.length) enqueue();
  }
  return results;
}

// Simple job lock to avoid overlapping runs of the same cron job (in-process)
const jobLocks = new Set();
async function runIfNotRunning(name, fn) {
  if (jobLocks.has(name)) {
    console.log(`[cron] Skipping ${name} because previous run still in progress`);
    return;
  }
  jobLocks.add(name);
  try {
    await fn();
  } catch (err) {
    throw err;
  } finally {
    jobLocks.delete(name);
  }
}

function sleep(ms) {
  return new Promise((r) => setTimeout(r, ms));
}

function startCrons() {
  // Keep references to scheduled tasks so we can stop them during shutdown
  const scheduledTasks = [];

  // 1) Live sync — every 2 minutes
  // Use the explicit live endpoint so we only fetch live fixtures frequently.
  const liveNowTask = cron.schedule("*/2 * * * *", async () => {
    await runIfNotRunning('live-now', async () => {
      try {
        const { data } = await api.post('/api/sync/live-now', {});
        console.log('[cron] live-now sync ok', { foundLive: data.foundLive, upserts: data.upsertedCount });
      } catch (e) {
        const body = e?.response?.data || e.message;
        console.error('[cron] live-now sync failed', body);
        const is429 = e?.response?.status === 429 || /rate limit/i.test(JSON.stringify(body || ''));
        if (is429) {
          const COOL_OFF_MS = Number(process.env.CRON_PROVIDER_COOLDOWN_MS || 60_000);
          console.warn(`[cron] live-now rate-limited. Cooling off for ${COOL_OFF_MS}ms before next run.`);
          await sleep(COOL_OFF_MS);
        }
      }
    });
  });
  scheduledTasks.push(liveNowTask);

  // Also run a daily date sync (once) to capture any fixtures the live feed may miss.
  const dailyDateTask = cron.schedule('5 3 * * *', async () => {
    try {
      const today = new Date();
      const pad = (n) => String(n).padStart(2, '0');
      const y = today.getUTCFullYear();
      const m = pad(today.getUTCMonth() + 1);
      const d = pad(today.getUTCDate());
      const { data } = await axios.post(`${BASE}/api/sync/date/${y}/${m}/${d}`, {}, { headers: { 'x-api-key': ADMIN_KEY } });
      console.log('[cron] daily/date sync ok', { date: `${y}-${m}-${d}`, upserts: data.upsertedCount });
    } catch (e) {
      const body = e?.response?.data || e.message;
      console.error('[cron] daily/date sync failed', body);
    }
  });
  scheduledTasks.push(dailyDateTask);

  // ─────────────────────────────────────────────────────────────
  // 2) Daily league-window sync (+ snapshot recompute)
  // This job now focuses on forward-looking date/time checks (no pastDays)
  // Runs once daily at 03:00 UTC by default. Configure with CRON_LEAGUE_WINDOW_CRON.
  const leagueWindowCron = process.env.CRON_LEAGUE_WINDOW_CRON || '0 3 * * *';
  const leagueWindowTask = cron.schedule(leagueWindowCron, async () => {
    await runIfNotRunning('league-window', async () => {
      console.log("[cron] Starting league window sync batch...");
      try {
        const leagueObjs = await getLeaguesWithFallback();
        const leagueIds = (leagueObjs || []).map(x => x.id).filter(Number.isFinite);

        if (!leagueIds || !leagueIds.length) {
          console.log('[cron] No league ids discovered; skipping league-window sync this run.');
          return;
        }

  // Reduce batch size by default since we're only checking forward date/time changes
  const BATCH_SIZE = Number(process.env.CRON_BATCH_SIZE || 10); // how many leagues per run
  const PER_LEAGUE_DELAY_MS = Number(process.env.CRON_LEAGUE_DELAY_MS || 1500);

        let processed = 0;
        for (const lid of leagueIds) {
          if (processed >= BATCH_SIZE) break;
          try {
            // Request a minimal, forward-only check to detect date/time changes.
            const body = { pastDays: 0, futureDays: 30, dateOnly: true, minimal: true };
            const syncRes = await throttledApiPost(`/api/sync/league/${lid}/window`, body, { timeout: 5*60*1000 });
            console.log(`[cron] League forward-check: ${lid} (upserts=${syncRes.data.upsertedCount || 'n/a'} fetched=${syncRes.data.totalFetched || 'n/a'})`);
          } catch (e) {
            const body = e?.response?.data;
            const is429 = e?.response?.status === 429 || /rate limit/i.test(JSON.stringify(body || ''));
            console.error(`[cron] League ${lid} failed`, body || e.message);
            if (is429) {
              const COOL_OFF_MS = Number(process.env.CRON_COOL_OFF_MS || 60_000);
              console.warn(`[cron] Rate limited. Cooling off ${COOL_OFF_MS}ms and ending this batch.`);
              await new Promise(r => setTimeout(r, COOL_OFF_MS));
              break;
            }
          }
          processed += 1;
          await new Promise(r => setTimeout(r, PER_LEAGUE_DELAY_MS));
        }

        console.log(`[cron] League window sync processed ${processed} leagues this run.`);
      } catch (err) {
        console.error('[cron] League-window sync failed', err?.response?.data || err.message || err);
      }
    });
  });
  scheduledTasks.push(leagueWindowTask);

  console.log("[cron] Scheduler started.");

  // ─────────────────────────────────────────────────────────────
  // 3) Pre-match lineup fetch: every 5 minutes, check for matches starting
  // within a configurable lookahead window and attempt to fetch/persist lineups
  // from SportMonks. Defaults to matches starting between 30 and 60 minutes.
  const preMatchLineupTask = cron.schedule('*/5 * * * *', async () => {
      try {
        const now = new Date();

  // Default to checking between 45 and 70 minutes before kickoff: provider
  // lineups are typically available around an hour prior, so this widens
  // the window to improve catch-rate while keeping the window bounded.
  const LOOKAHEAD_MIN_DEFAULT = 45; // minutes in future to start looking
  const LOOKAHEAD_MAX_DEFAULT = 70; // minutes in future to stop looking

        const lookaheadMin = Number(process.env.CRON_PREMATCH_LOOKAHEAD_MIN || LOOKAHEAD_MIN_DEFAULT);
        const lookaheadMax = Number(process.env.CRON_PREMATCH_LOOKAHEAD_MAX || LOOKAHEAD_MAX_DEFAULT);

        if (!Number.isFinite(lookaheadMin) || !Number.isFinite(lookaheadMax) || lookaheadMin < 0 || lookaheadMax <= 0 || lookaheadMin >= lookaheadMax) {
          console.warn('[cron] Invalid pre-match lookahead config; falling back to defaults.');
        }

        const windowStart = new Date(now.getTime() + (Math.max(0, lookaheadMin) * 60 * 1000));
        const windowEnd = new Date(now.getTime() + (Math.max(lookaheadMin + 1, lookaheadMax) * 60 * 1000));

        // Allow a small slack to catch slight clock differences/provider rounding
        const SLACK_MS = Number(process.env.CRON_PREMATCH_SLACK_MS || (3 * 60 * 1000)); // default 3 minutes
        windowStart.setTime(windowStart.getTime() - SLACK_MS);
        windowEnd.setTime(windowEnd.getTime() + SLACK_MS);

        // Find matches scheduled to start in the lookahead window.
        // Be robust: some legacy documents may have the top-level `date` field or
        // an integer `match_info.starting_at_timestamp` instead of a Date in
        // `match_info.starting_at`. Query all likely locations so we don't miss
        // matches due to mixed formats.
        const Match = require('../models/Match');
        const startTs = Math.floor(windowStart.getTime() / 1000);
        const endTs = Math.floor(windowEnd.getTime() / 1000);
        const upcoming = await Match.find({
          $or: [
            { 'match_info.starting_at': { $gte: windowStart, $lte: windowEnd } },
            { date: { $gte: windowStart, $lte: windowEnd } },
            { 'match_info.starting_at_timestamp': { $gte: startTs, $lte: endTs } }
          ]
        }).lean();

        const targetDescr = `${lookaheadMin}-${lookaheadMax}min`;
        if (!upcoming || !upcoming.length) {
          return console.log(`[cron] No matches due for lineup fetch in ${targetDescr} window around ${windowStart.toISOString()} - ${windowEnd.toISOString()}.`);
        }

        console.log(`[cron] Found ${upcoming.length} matches to check for lineups in ${targetDescr} window`);

        const { fetchMatchStats } = require('../controllers/matchSyncController');
        const { normaliseFixtureToMatchDoc } = require('../utils/normaliseFixture');

        for (const m of upcoming) {
          try {
            const sm = await fetchMatchStats(m.match_id);
            if (!sm) continue;
            const norm = normaliseFixtureToMatchDoc(sm) || {};
            let lineup = (norm && norm.lineup) ? norm.lineup : { home: [], away: [] };

            // Persist lineup but DO NOT attach ratings at pre-match time.
            const lineupToSave = { home: (lineup.home || []).map(p => ({ ...p, rating: null })), away: (lineup.away || []).map(p => ({ ...p, rating: null })) };
            // Build flattened lineups array to match the new Match.schema shape
            const lineupsFlattened = [];
            const pushFlat = (arr, teamId) => {
              for (const p of (arr || [])) {
                lineupsFlattened.push({
                  player_id: p.player_id ?? null,
                  team_id: p.team_id ?? teamId ?? null,
                  player_name: p.player_name || p.name || p.player || '',
                  position_id: p.position_id ?? p.position ?? null,
                  formation_field: p.formation_field ?? null,
                  formation_position: p.formation_position ?? p.role ?? null,
                  jersey_number: p.jersey_number ?? p.number ?? null,
                  type_id: p.type_id ?? null,
                  details: []
                });
              }
            };
            pushFlat(lineupToSave.home || [], m.home_team_id || m.homeId || null);
            pushFlat(lineupToSave.away || [], m.away_team_id || m.awayId || null);

            // persist lineup and flattened lineups into match document
            await Match.findOneAndUpdate({ match_id: m.match_id }, { $set: { lineup: lineupToSave, lineups: lineupsFlattened } });
            console.log(`[cron] Persisted lineup for match ${m.match_id} (fetched with include: ${sm._fetched_with_include || 'unknown'})`);
          } catch (e) {
            console.warn('[cron] Failed to fetch/persist lineup for match', m.match_id, e?.message || e);
          }
          // small delay between match calls to reduce burst
          await sleep(500);
        }
      } catch (err) {
        console.error('[cron] pre-match lineup fetch job failed', err?.response?.data || err.message || err);
      }
  });
  scheduledTasks.push(preMatchLineupTask);

  // duplicate pre-match block removed above; single preMatchLineupTask is scheduled

  // schedule auto-generate reports once daily at 04:30 UTC
  const reportsTask = cron.schedule('30 4 * * *', async () => {
    await runIfNotRunning('reports-daily', async () => {
      try {
        await autoGenerateReportsForFinishedMatches();
      } catch (e) {
        console.error('[cron] auto-generate reports failed', e?.message || e);
      }
    });
  });
  scheduledTasks.push(reportsTask);

  // Update stale team match info once daily at 05:00 UTC
  // This ensures stored last_match_info/next_match_info are refreshed based on current date
  const teamMatchInfoTask = cron.schedule('0 5 * * *', async () => {
    await runIfNotRunning('team-match-info-refresh', async () => {
      try {
        console.log('[cron] Starting daily team match info refresh...');
        await refreshStaleTeamMatchInfo();
        console.log('[cron] Completed daily team match info refresh.');
      } catch (e) {
        console.error('[cron] team match info refresh failed', e?.message || e);
      }
    });
  });
  scheduledTasks.push(teamMatchInfoTask);

  // New task: three-week lookahead per-day, per-league (sequential) to reduce provider rate pressure
  // Runs once daily; for each day from today..+20 days (3 weeks) it will call per-league sync
  // Run hourly and process a chunk of leagues each hour so calls are staggered across the day.
  // Default: 24 chunks -> one chunk per UTC hour. Configure with CRON_LOOKAHEAD_CHUNKS_PER_DAY.
  const threeWeekLookaheadTask = cron.schedule('0 * * * *', async () => {
    await runIfNotRunning('3w-lookahead', async () => {
      console.log('[cron] Starting 3-week lookahead per-day per-league sync...');
      try {
        const leagueObjs = await getLeaguesWithFallback();
        if (!leagueObjs || !leagueObjs.length) return console.log('[cron] No leagues discovered for 3-week lookahead; skipping.');

        // Attempt to filter to European leagues when possible (best-effort).
        const europeFiltered = leagueObjs.filter(l => {
          try {
            if (l.region && String(l.region).toLowerCase().includes('europe')) return true;
            if (l.country && (l.country.continent || l.country.continent_name) && String(l.country.continent || l.country.continent_name).toLowerCase().includes('europe')) return true;
            if (String(l.name).toLowerCase().includes('europe')) return true;
          } catch (e) {}
          return false;
        });
        const candidates = (europeFiltered.length ? europeFiltered : leagueObjs).map(x => x.id);

        const PER_LEAGUE_DELAY_MS = Number(process.env.CRON_LEAGUE_DELAY_MS || 1500);

        // Chunking config: how many chunks to split the league list into across the day.
        // Default 24 => one chunk per UTC hour.
        const CHUNKS_PER_DAY = Number(process.env.CRON_LOOKAHEAD_CHUNKS_PER_DAY || 24);
        const now = new Date();
        const chunkIndex = now.getUTCHours() % Math.max(1, CHUNKS_PER_DAY);

        // Determine subset for this run using a modulo distribution to spread evenly.
        const subset = candidates.filter((_, idx) => (idx % CHUNKS_PER_DAY) === chunkIndex);

        // Target the single date exactly 21 days from now. This keeps the DB 3 weeks ahead
        // while dramatically reducing the number of calls (1 call per league per run per chunk).
        // Anchor target date to UTC midnight of the current UTC day, then add 21 days.
        const utcTodayMidnight = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate()));
        const dt = new Date(utcTodayMidnight.getTime() + 21 * 24 * 3600 * 1000);
        const y = dt.getUTCFullYear();
        const m = String(dt.getUTCMonth() + 1).padStart(2, '0');
        const d = String(dt.getUTCDate()).padStart(2, '0');
        console.log(`[cron] Lookahead single-day => ${y}-${m}-${d} (total leagues=${candidates.length}, chunks=${CHUNKS_PER_DAY}, this chunk=${chunkIndex}, chunk size=${subset.length})`);

        // Concurrency: how many league syncs to run in parallel from this chunk.
        const LOOKAHEAD_CONCURRENCY = Number(process.env.CRON_LOOKAHEAD_CONCURRENCY || 1);

        // Worker for each league that uses the throttled post helper
        const worker = async (lid) => {
          try {
            const body = { pastDays: 0, futureDays: 0, date: `${y}-${m}-${d}` };
            const syncRes = await throttledApiPost(`/api/sync/league/${lid}/window`, body, { timeout: 5 * 60 * 1000 });
            console.log(`[cron] league ${lid} date ${y}-${m}-${d} OK: upserted=${syncRes.data.upsertedCount || 'n/a'} fetched=${syncRes.data.totalFetched || 'n/a'}`);
          } catch (e) {
            console.warn(`[cron] league ${lid} date ${y}-${m}-${d} failed`, e?.response?.data || e.message || e);
          }
          // small delay between leagues to reduce burst (in addition to throttling)
          await sleep(PER_LEAGUE_DELAY_MS);
        };

        // Run the chunk with concurrency
        await runWithConcurrency(subset, worker, Math.max(1, LOOKAHEAD_CONCURRENCY));
        console.log('[cron] Completed 3-week lookahead per-day per-league sync.');
      } catch (err) {
        console.error('[cron] 3-week lookahead job failed', err?.response?.data || err.message || err);
      }
    });
  });
  scheduledTasks.push(threeWeekLookaheadTask);

  // ─────────────────────────────────────────────────────────────
  // TESTING PHASE ONLY: Daily fixture seeding cron job
  // 🚨 REMOVE ON NOVEMBER 16TH, 2024 OR BEFORE PRODUCTION LAUNCH 🚨
  // This job seeds fixtures daily during testing phase to reduce API strain
  // Runs at 02:00 UTC daily - well before fixtures are likely to start
  // ─────────────────────────────────────────────────────────────
  
  // Check if we're before the expiration date (November 16th, 2024)
  const TESTING_EXPIRY_DATE = new Date('2024-11-16T00:00:00Z');
  const currentDate = new Date();
  
  if (currentDate < TESTING_EXPIRY_DATE) {
    const testingSeedTask = cron.schedule('0 2 * * *', async () => {
      await runIfNotRunning('testing-daily-seed', async () => {
        console.log("[cron] 🧪 TESTING: Starting daily fixture seeding (expires Nov 16th, 2024)...");
        
        try {
          const leagueObjs = await getLeaguesWithFallback();
          if (!leagueObjs || !leagueObjs.length) {
            console.log('[cron] 🧪 TESTING: No leagues discovered for daily seeding; skipping.');
            return;
          }

          // Filter to European leagues for better coverage during testing
          const europeFiltered = leagueObjs.filter(l => {
            try {
              if (l.region && String(l.region).toLowerCase().includes('europe')) return true;
              if (l.country && (l.country.continent || l.country.continent_name) && String(l.country.continent || l.country.continent_name).toLowerCase().includes('europe')) return true;
              if (String(l.name).toLowerCase().includes('europe')) return true;
            } catch (e) {}
            return false;
          });
          
          const targetLeagues = (europeFiltered.length ? europeFiltered : leagueObjs).map(x => x.id);
          console.log(`[cron] 🧪 TESTING: Processing ${targetLeagues.length} leagues for daily seeding`);

          // Process 3 days: today, tomorrow, and day after tomorrow
          const today = new Date();
          const dates = [];
          for (let i = 0; i < 3; i++) {
            const targetDate = new Date(today.getTime() + (i * 24 * 60 * 60 * 1000));
            const y = targetDate.getUTCFullYear();
            const m = String(targetDate.getUTCMonth() + 1).padStart(2, '0');
            const d = String(targetDate.getUTCDate()).padStart(2, '0');
            dates.push(`${y}-${m}-${d}`);
          }

          // Process fewer leagues per run to be gentle on the API
          const MAX_LEAGUES_PER_RUN = Number(process.env.CRON_TESTING_MAX_LEAGUES || 15);
          const targetSubset = targetLeagues.slice(0, MAX_LEAGUES_PER_RUN);
          const PER_LEAGUE_DELAY_MS = Number(process.env.CRON_TESTING_DELAY_MS || 2000); // Longer delay during testing

          console.log(`[cron] 🧪 TESTING: Seeding ${targetSubset.length} leagues for dates: ${dates.join(', ')}`);

          for (const leagueId of targetSubset) {
            for (const dateStr of dates) {
              try {
                const body = { pastDays: 0, futureDays: 0, date: dateStr };
                const syncRes = await throttledApiPost(`/api/sync/league/${leagueId}/window`, body, { timeout: 5 * 60 * 1000 });
                console.log(`[cron] 🧪 TESTING: League ${leagueId} date ${dateStr} OK: upserted=${syncRes.data.upsertedCount || 'n/a'} fetched=${syncRes.data.totalFetched || 'n/a'}`);
              } catch (e) {
                console.warn(`[cron] 🧪 TESTING: League ${leagueId} date ${dateStr} failed`, e?.response?.data || e.message || e);
                
                // If rate limited, take a longer break during testing
                const is429 = e?.response?.status === 429 || /rate limit/i.test(JSON.stringify(e?.response?.data || ''));
                if (is429) {
                  const COOL_OFF_MS = Number(process.env.CRON_TESTING_COOLOFF_MS || 120000); // 2 minutes default
                  console.warn(`[cron] 🧪 TESTING: Rate limited. Cooling off ${COOL_OFF_MS}ms`);
                  await sleep(COOL_OFF_MS);
                }
              }
              
              // Delay between each API call
              await sleep(PER_LEAGUE_DELAY_MS);
            }
          }

          console.log('[cron] 🧪 TESTING: Completed daily fixture seeding');
        } catch (err) {
          console.error('[cron] 🧪 TESTING: Daily fixture seeding failed', err?.response?.data || err.message || err);
        }
      });
    });
    
    scheduledTasks.push(testingSeedTask);
    console.log("[cron] 🧪 TESTING: Daily fixture seeding scheduled (expires Nov 16th, 2024)");
  } else {
    console.log("[cron] ⏰ TESTING: Daily fixture seeding EXPIRED (past Nov 16th, 2024) - job not scheduled");
  }

  // Expose a stopper for server shutdown
  async function stopCrons() {
    console.log('[cron] Stopping scheduled tasks...');
    for (const t of scheduledTasks) {
      try {
        if (t && typeof t.stop === 'function') t.stop();
      } catch (e) {
        console.warn('[cron] Failed to stop a task', e?.message || e);
      }
    }
  }

  // attach stopper to module exports dynamically
  module.exports.stopCrons = stopCrons;
}

async function autoGenerateReportsForFinishedMatches() {
  try {
    // load Match model lazily
    const Match = require('../models/Match');
    // find matches finished in the last X hours (UTC), without generated reports
    const twoDaysAgo = new Date(Date.now() - (2 * 24 * 3600 * 1000));
    const now = new Date();

    // Only consider matches without any reports for either side to avoid duplicates.
    const matches = await Match.find({
      'match_info.starting_at': { $gte: twoDaysAgo, $lte: now },
      $or: [
        { 'reports.home': { $exists: false } },
        { 'reports.away': { $exists: false } },
        { reports: { $exists: false } }
      ]
    }).limit(100).lean();

    if (!matches || !matches.length) return console.log('[cron] No finished matches needing reports.');

    for (const m of matches) {
      try {
        // call your own protected endpoint (preferred) so same logic used
        const ADMIN_KEY = process.env.ADMIN_API_KEY;
        const BASE = process.env.SELF_BASE || 'http://localhost:8000';
        // generate both
        // Call the protected endpoint which has internal idempotency checks.
        await axios.post(`${BASE}/api/reports/${m.home_team_slug || m.home_team.toLowerCase().replace(/\s+/g,'-')}/match/${m.match_id}/generate-both`, {}, {
          headers: { 'x-api-key': ADMIN_KEY }
        });
        console.log(`[cron] Generated reports for match ${m.match_id}`);
        // small delay
        await new Promise(r => setTimeout(r, 800));
      } catch (e) {
        console.error('[cron] live report generation failed for', m.match_id, e?.response?.data || e.message || e);
      }
    }
  } catch (err) {
    console.error('[cron] autoGenerateReportsForFinishedMatches error', err);
  }
}

async function refreshStaleTeamMatchInfo() {
  try {
    const Team = require('../models/Team');
    const { getDynamicTeamMatchInfo } = require('../utils/teamMatchUtils');
    
    // Process teams in batches to avoid overwhelming the database
    const BATCH_SIZE = Number(process.env.CRON_TEAM_BATCH_SIZE || 50);
    const DELAY_MS = Number(process.env.CRON_TEAM_DELAY_MS || 100);

    // Get all teams, processing in batches
    let skip = 0;
    let processed = 0;
    let updated = 0;
    let errors = 0;

    while (true) {
      const teams = await Team.find({})
        .select('id slug name last_match_info next_match_info last_played_at next_game_at')
        .skip(skip)
        .limit(BATCH_SIZE)
        .lean();

      if (!teams || teams.length === 0) break;

      console.log(`[cron] Processing team match info batch: ${skip + 1}-${skip + teams.length}`);

      for (const team of teams) {
        try {
          // Get current dynamic match info
          const currentInfo = await getDynamicTeamMatchInfo(team.slug, team.name);
          
          // Check if we need to update (compare dates to avoid unnecessary writes)
          const needsUpdate = (
            // Last match changed
            (currentInfo.last_match_info?.date?.getTime() !== team.last_match_info?.date?.getTime()) ||
            // Next match changed  
            (currentInfo.next_match_info?.date?.getTime() !== team.next_match_info?.date?.getTime()) ||
            // Handle cases where one is null but the other isn't
            (!currentInfo.last_match_info !== !team.last_match_info) ||
            (!currentInfo.next_match_info !== !team.next_match_info)
          );

          if (needsUpdate) {
            await Team.findOneAndUpdate(
              { slug: team.slug },
              {
                $set: {
                  last_match_info: currentInfo.last_match_info,
                  next_match_info: currentInfo.next_match_info,
                  last_played_at: currentInfo.last_played_at,
                  next_game_at: currentInfo.next_game_at
                }
              }
            );
            updated++;
            console.log(`[cron] Updated team match info: ${team.slug}`);
          }

          processed++;
          await sleep(DELAY_MS);
        } catch (e) {
          errors++;
          console.error(`[cron] Failed to refresh match info for team ${team.slug}:`, e?.message || e);
        }
      }

      skip += BATCH_SIZE;
    }

    console.log(`[cron] Team match info refresh complete: ${processed} processed, ${updated} updated, ${errors} errors`);
  } catch (err) {
    console.error('[cron] refreshStaleTeamMatchInfo error', err?.message || err);
  }
}


module.exports = { startCrons };
