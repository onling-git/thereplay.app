# Testing Phase Environment Variables
# Copy this to .env.local for local development

# Basic Authentication Credentials
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=testing123

# Set to true during testing phase to enable extra protection
REACT_APP_TESTING_MODE=true

# Disable analytics and tracking during testing
REACT_APP_DISABLE_ANALYTICS=true
REACT_APP_DISABLE_ADSENSE=true